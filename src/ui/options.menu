#include "ui/menudef.h"

{
\\ SETUP MENU \\

menuDef {
    	name "options_menu"
    	visible 0
    	fullscreen 0
	rect 186 0 443 426
    	focusColor 1 .75 0 1
    	style 1
    	border 1
	onOpen { setitemcolor fadebox backcolor 0 0 0 1 ; 
		fadeout fadebox }
	onEsc { close options_menu ; close setup_menu }
	



itemDef {
	name window
	group grpControlbutton
	rect 0 2 443 426	
	style WINDOW_STYLE_FILLED
	border 1
	bordercolor .5 .5 .5 .5
	forecolor 1 1 1 1
	backcolor 0 0 0 .25
	visible 1
	decoration
}







// 	HUD		//

itemDef {
      	name hud
		group grpOptions
		style WINDOW_STYLE_FILLED
	backcolor 0 0 0 .25 
 	rect 56 6 100 26
      	visible 1 
	decoration  	  
    	}

itemDef {
	name ctr_hud
	text "HUD"
	type 1
	textscale .3
	group grpOptionsbutton
	style WINDOW_STYLE_FILLED
	rect 56 6 100 26
	textalign 1
	textalignx 50
	textaligny 20
	forecolor 1 1 1 1
	visible 1
	action { play "sound/misc/menu1.wav" ; 
	hide grpOptions ; show hud }
	mouseEnter { show message_hud } 
	mouseExit { hide message_hud } 
	}


itemDef {
	name hud
	group grpOptions
	rect 2 30 439 396	
	style WINDOW_STYLE_FILLED
	border 1
	bordercolor .5 .5 .5 .5
	forecolor 1 1 1 1
	backcolor 0 0 0 .25
	visible 0
	decoration
}

	itemDef {
      		name hud
		group grpOptions
      		type ITEM_TYPE_YESNO
		text "Identify Target:"
		cvar "cg_drawCrosshairNames"
		rect 99 35 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .3
      		forecolor 1 1 1 1
      		visible 1 
    		}

	itemDef {
      		name hud
		group grpOptions
      		type ITEM_TYPE_YESNO
		text "Draw Team Overlay:"
		cvar "cg_drawTeamOverlay"
		rect 99 55 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .3
      		forecolor 1 1 1 1
      		visible 1 
    		}
	itemDef {
      		name hud
		group grpOptions
      		type ITEM_TYPE_SLIDER
		text "Screen Size:"
		cvarfloat "cg_viewsize" 100 30 100
		rect 99 75 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333        
      		forecolor 1 1 1 1
      		visible 1 
    		}
	itemDef {
      		name hud
		group grpOptions
      		type ITEM_TYPE_YESNO
		text "Show Time:"
		cvar "cg_drawTimer"
		rect 99 95 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .3
      		forecolor 1 1 1 1
      		visible 1 
    		}

itemDef {
      		name hud
		group grpOptions
      		type ITEM_TYPE_MULTI	
		text "Statusbar:"
		cvar "cg_hudfiles"
	//	cvarStrList { Normal "ui/hud.txt" Small "ui/hud2.txt" }
		cvarStrList { Normal "ui/hud.txt" }
		rect 99 115 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .3        
      		forecolor 1 1 1 1
      		visible 1  
	}

itemDef {
      		name hud				
		group grpOptions
		text "Crosshair:"
		rect 227 135 20 20
		ownerdraw UI_CROSSHAIR
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 0 
      		textaligny 20
		textscale .3        
      		forecolor 1 1 1 1
      		visible 1 
    		}






// 	DISPLAY		//

itemDef {
      	name display
		group grpOptions
		style WINDOW_STYLE_FILLED
	backcolor 0 0 0 .25 
 	rect 181 6 100 26
      	visible 1 
	decoration  	  
    	}

itemDef {
	name ctr_display
