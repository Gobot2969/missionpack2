	textalign 1
	textalignx 50
	textaligny 20
	forecolor 1 1 1 1
	visible 1
	action { play "sound/misc/menu1.wav" ; 
	hide grpOptions ; show display }
	mouseEnter { show message_display } 
	mouseExit { hide message_display } 
	}


