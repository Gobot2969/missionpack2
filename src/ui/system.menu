	style WINDOW_STYLE_FILLED
	rect 181 6 100 26
	textalign 1
	textalignx 50
	textaligny 20
	forecolor 1 1 1 1
	visible 1
	action { play "sound/misc/menu1.wav" ; 
	hide grpSystem ; show sound }
	mouseEnter { show message_driver } 
	mouseExit { hide message_driver } 
	}

itemDef {
	name sound
	group grpSystem
	rect 2 30 439 396	
	style WINDOW_STYLE_FILLED
	border 1
	bordercolor .5 .5 .5 .5
	forecolor 1 1 1 1
	backcolor 0 0 0 .25
	visible 0
	decoration
}

	itemDef {
      		name sound
		group grpSystem
      		type ITEM_TYPE_SLIDER
		text "Effects Volume:"
		cvarfloat "s_volume" 0.7 0 1
		rect 99 52 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333       
      		forecolor 1 1 1 1
      		visible 0 
    		}
	
	itemDef {
      		name sound
		group grpSystem
      		type ITEM_TYPE_SLIDER
		text "Music Volume:"
		cvarfloat "s_musicvolume" 0.25 0 1
		rect 99 79 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333        
      		forecolor 1 1 1 1
      		visible 0 
    		}

	itemDef {
      		name sound
		group grpSystem
      		type ITEM_TYPE_MULTI
		text "Sound Quality:"
		cvar "s_khz"
		cvarFloatList { "11 khz (low)" 11 "22 khz (medium)" 22 "44 khz (high)" 44 }
		rect 99 106 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333        
      		forecolor 1 1 1 1
      		visible 0 
    		}

	itemDef {
      		name sound
		group grpSystem
      		type ITEM_TYPE_YESNO
		text "Doppler Sound:"
		cvar "s_doppler"
		rect 99 133 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333        
