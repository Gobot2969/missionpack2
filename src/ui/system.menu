// 	Network		//

itemDef {
      	name network
		group grpSystem
	style WINDOW_STYLE_FILLED
	backcolor 0 0 0 .25 
 	rect 306 6 100 26
      	visible 1 
	decoration  	  
}

itemDef {
	name ctr_network
	text "Network"
	type 1
	textscale .3
	group grpSystembutton
	style WINDOW_STYLE_FILLED
	rect 306 6 100 26
	textalign 1
	textalignx 50
	textaligny 20
	forecolor 1 1 1 1
	visible 1
	action { play "sound/misc/menu1.wav" ; 
	hide grpSystem ; show network }
	mouseEnter { show message_other } 
	mouseExit { hide message_other } 	
	}
itemDef {
	name network
	group grpSystem
	rect 2 30 439 396	
	style WINDOW_STYLE_FILLED
	border 1
	bordercolor .5 .5 .5 .5
	forecolor 1 1 1 1
	backcolor 0 0 0 .25
	visible 0
	decoration
}


itemDef {
      		name network
		group grpSystem
      		type ITEM_TYPE_MULTI
		text "Net Data Rate:"
		cvar "rate"
		cvarFloatList { "<=28.8k" 2500 "33.6k" 3000 "56k" 4000 "ISDN" 5000 "LAN/CABLE/xDSl" 25000  }
		rect 99 52 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333        
      		forecolor 1 1 1 1
      		visible 0 
			action { uiScript update ui_setRate }
}

	itemDef {
      		name network
		group grpSystem
      		type ITEM_TYPE_YESNO
		text "Auto Download:"
		cvar "cl_allowDownload"
		rect 99 79 256 20
      		textalign ITEM_ALIGN_RIGHT
      		textalignx 128
      		textaligny 20
		textscale .333
      		forecolor 1 1 1 1
      		visible 0 
    		}


itemDef {
      	name fadebox
      	style WINDOW_STYLE_FILLED
 	background "ui/assets/fadebox.tga"
	forecolor 0 0 0 1
	backcolor 0 0 0 1
	rect 0 0 640 480
      	visible 1 
	decoration
    	}

	


}


}
