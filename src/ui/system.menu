		group grpSystem
	style WINDOW_STYLE_FILLED
	backcolor 0 0 0 .25 
 	rect 181 6 100 26
      	visible 1 
	decoration  	  
    	}

itemDef {
	name ctr_sound
	text "Sound"
	type 1
	textscale .3
